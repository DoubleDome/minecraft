# Target: "live" or "test". Default is "test" (safer — won't clobber live pack).
# Override per-run with: node index.js live
TARGET=""

# Live deploy: where the running server reads its datapack from
BASE_PATH=""

# Pack folder name: appended onto BASE_PATH; same name for both targets
PACK_FOLDER=""

# Test runs load .env.test on top of .env with override:true.
# Put test-only overrides (typically a sandbox BASE_PATH) in .env.test.
# See .env.test.example for the scaffold.

RESOURCE_PATH=""
WORLD_PATH=""
FUNCTIONS_PATH=""
BACKUP_PATH=""
DELIMETER=""

# Optional — for the /status route in server.js
MC_HOST="localhost"
MC_PORT="25577"
SERVER_NAME="Toledo Survival Server"